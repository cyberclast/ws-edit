{
    "name": "ws-edit",
    "displayName": "WS Edit",
    "description": "Convenient status bar button to edit current workspace as JSON",
    "version": "0.2.0",
    "publisher": "cyberclast",
    "author": {
        "name": "Cyberclast Software Solutions Ltd.",
        "url": "https://cyberclast.com"
    },
    "icon": "img/icon-sm.png",
    "license": "MIT",
    "repository": {
        "type": "git",
        "url": "https://github.com/cyberclast/ws-edit.git"
    },
    "engines": {
        "vscode": "^1.85.0"
    },
    "categories": [
        "Other"
    ],
    "keywords": [
        "workspace",
        "jsonc",
        "multi-root",
        "folders"
    ],
    "galleryBanner": {
        "color": "#1f1f1f",
        "theme": "dark"
    },
    "activationEvents": [
        "onStartupFinished"
    ],
    "main": "./extension.js",
    "contributes": {
        "commands": [
            {
                "command": "ws-edit.open",
                "title": "WS Edit: Edit current workspace as JSON"
            }
        ]
    },
    "scripts": {
        "lint": "eslint .",
        "build": "vsce package",
        "install-local": "vsce package && code --install-extension ws-edit-$npm_package_version.vsix"
    },
    "devDependencies": {
        "@vscode/vsce": "^3.0.0",
        "eslint": "^8.0.0"
    }
}
